{
  "name": "tanaghum-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Tanaghum AI Commercial Automation Platform",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "lint": "eslint src/ modules/ shared/ --ext .ts",
    "lint:fix": "eslint src/ modules/ shared/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"modules/**/*.ts\" \"shared/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"modules/**/*.ts\" \"shared/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e:production": "playwright test e2e/production-acceptance.spec.ts --reporter=list --workers=1",
    "acceptance:seed": "node dist/seed-production-acceptance.js",
    "acceptance:cleanup": "node dist/seed-production-acceptance.js",
    "test:e2e": "playwright test",
    "test:e2e:acceptance": "playwright test e2e/sprint39-live-acceptance.spec.ts",
    "test:e2e:hybrid-live": "node scripts/run-hybrid-live-e2e.mjs",
    "test:e2e:agentic-hybrid-live": "node scripts/run-agentic-hybrid-e2e.mjs",
    "test:e2e:sprint65": "playwright test e2e/sprint65-customer-acceptance.spec.ts",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "tenant:purge": "tsx scripts/purge-tenant.ts",
    "queue:worker": "tsx src/workers.ts",
    "ci": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@langchain/langgraph": "^1.4.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^6.9.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.25.6",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^9.0.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.9.0",
    "rate-limiter-flexible": "^7.1.1",
    "uuid": "^11.1.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.6",
    "prisma": "^6.9.0",
    "tsc-alias": "^1.9.1",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "@hono/node-server": "2.0.11"
  }
}
