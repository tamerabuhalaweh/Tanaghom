  updated_at       DateTime @updatedAt

  mcp_connector McpConnector @relation(fields: [mcp_connector_id], references: [id])

  @@unique([mcp_connector_id, tool_name])
  @@index([mcp_connector_id])
  @@map("mcp_discovered_tools")
}

model McpCapabilityBinding {
  id                     String   @id @default(uuid()) @db.Uuid
  capability_id          String   @db.Uuid
  implementation_id      String?  @db.Uuid
  mcp_connector_id       String   @db.Uuid
  allowed_operation      String   @default("read")
  requires_approval      Boolean  @default(false)
  requires_saif_decision Boolean  @default(false)
  requires_m5_authorization Boolean @default(false)
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt

  capability     Capability     @relation(fields: [capability_id], references: [id])
  implementation Implementation? @relation(fields: [implementation_id], references: [id])
  mcp_connector  McpConnector   @relation(fields: [mcp_connector_id], references: [id])

  @@unique([capability_id, implementation_id, mcp_connector_id])
  @@index([capability_id])
  @@index([mcp_connector_id])
  @@map("mcp_capability_bindings")
}

model McpMediationRequest {
  id                       String                 @id @default(uuid()) @db.Uuid
  capability_resolution_id String?                @db.Uuid
  mcp_connector_id         String                 @db.Uuid
  requested_operation      String
  resource_ids             String[]
  human_user_id            String                 @db.Uuid
  agent_rep_id             String                 @db.Uuid
  acting_agent_type        String
  acting_agent_id          String?
  saif_decision_record_id  String?                @db.Uuid
  approval_id              String?                @db.Uuid
  request_status           McpMediationRequestStatus @default(pending)
  requested_at             DateTime               @default(now())
  created_at               DateTime               @default(now())
  updated_at               DateTime               @updatedAt

  capability_resolution  CapabilityResolution?  @relation(fields: [capability_resolution_id], references: [id])
  mcp_connector          McpConnector           @relation(fields: [mcp_connector_id], references: [id])
  human_user             User                   @relation(fields: [human_user_id], references: [id])
  agent_rep              AgentRep               @relation(fields: [agent_rep_id], references: [id])
  saif_decision          SaifDecisionRecord?    @relation(fields: [saif_decision_record_id], references: [id])
  approval               Approval?              @relation(fields: [approval_id], references: [id])
  decisions              McpMediationDecision[]
  spine_runs             SpineRun[]

  @@index([mcp_connector_id])
  @@index([request_status])
  @@index([human_user_id])
  @@map("mcp_mediation_requests")
}

model McpMediationDecision {
  id                    String               @id @default(uuid()) @db.Uuid
  mediation_request_id  String               @db.Uuid
  decision              McpMediationDecisionType
  rationale             String?              @db.Text
  policy_matched        String?
  decided_by_user_id    String?              @db.Uuid
  decided_by_agent_rep_id String?            @db.Uuid
  decided_at            DateTime             @default(now())
  created_at            DateTime             @default(now())

  mediation_request     McpMediationRequest  @relation(fields: [mediation_request_id], references: [id])
  decided_by_user       User?                @relation(fields: [decided_by_user_id], references: [id])
  decided_by_agent_rep  AgentRep?            @relation(fields: [decided_by_agent_rep_id], references: [id])
  spine_runs            SpineRun[]

  @@index([mediation_request_id])
  @@index([decision])
  @@map("mcp_mediation_decisions")
}

model McpAccessPolicy {
  id                     String   @id @default(uuid()) @db.Uuid
  name                   String   @unique
  description            String?  @db.Text
  connector_type         String?
  operation_type         String?
  allowed                Boolean  @default(true)
  requires_m4            Boolean  @default(true)
  requires_m5            Boolean  @default(false)
  requires_saif_decision Boolean  @default(false)
  requires_approval      Boolean  @default(false)
  conditions             Json?
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt

  @@index([connector_type])
  @@map("mcp_access_policies")
}

model McpCredentialBinding {
  id                  String            @id @default(uuid()) @db.Uuid
  mcp_connector_id    String            @db.Uuid
