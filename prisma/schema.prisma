// Prisma Schema — Tanaghum AI Commercial Automation Platform
//
// PROVISIONAL DRAFT — This schema is a foundation draft based on DATA_MODEL.md.
// It is expected to evolve sprint by sprint as business modules are implemented.
// Each sprint will add, modify, or refine models and enums as needed.
// Do NOT treat this schema as final until all sprints are complete.
//
// Current status: Sprint 6 — SAIF Decision Records & DKS Foundation.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Auth & Users
// ============================================================

enum Role {
  admin
  cco
  department_head
  specialist
  reviewer
  viewer
}

enum AgentType {
  functional
  governance
}

enum AgentStatus {
  active
  inactive
  suspended
}

enum TenantStatus {
  active
  suspended
  archived
}

enum TenantPlanStatus {
  active
  retired
}

enum TenantSubscriptionStatus {
  trialing
  active
  past_due
  suspended
  cancelled
  expired
}

enum TenantSubscriptionSource {
  manual
  stripe
  external_contract
}

enum CommercialWorkflowRunStatus {
  active
  blocked
  completed
  cancelled
}

enum CommercialWorkflowStageId {
  brief
  draft
  optimize
  approval
  package
  postiz
  analytics
  leads
  evidence
}

enum CommercialWorkflowStepStatus {
  done
  active
  waiting
  blocked
}

model Tenant {
  id          String       @id @default(uuid()) @db.Uuid
  tenant_key  String       @unique
  name        String
  status      TenantStatus @default(active)
  default_currency CommercialCurrency @default(AED)
  privacy_policy Json         @default("{}")
  privacy_review_status String @default("pending_customer_legal_review")
  privacy_review_updated_at DateTime?
  privacy_review_updated_by_user_id String? @db.Uuid
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt

  users       User[]
  memberships TenantMembership[]
  content_requests ContentRequest[]
  content_items ContentItem[]
  approvals Approval[]
  publishing_packages PublishingPackage[]
  analytics_ingestion_requests AnalyticsIngestionRequest[]
  analytics_snapshots AnalyticsSnapshot[]
  campaign_performance_reports CampaignPerformanceReport[]
  lead_capture_records LeadCaptureRecord[]
  commercial_workflow_runs CommercialWorkflowRun[]
  commercial_events CommercialEvent[]
  event_kpi_records EventKpiRecord[]
  event_email_plans EventEmailPlan[]
  event_whatsapp_plans EventWhatsappPlan[]
  event_upsell_plans EventUpsellPlan[]
  event_content_requirements EventContentRequirement[]
  event_sales_tasks EventSalesTask[]
  lead_lifecycle_events LeadLifecycleEvent[]
  ghl_lead_sync_runs GhlLeadSyncRun[]
  event_problems EventProblem[]
  connector_import_jobs ConnectorImportJob[]
  connector_field_mappings ConnectorFieldMapping[]
  commercial_revenue_lines CommercialRevenueLine[]
  commercial_plans CommercialPlan[]
  annual_commercial_plans AnnualCommercialPlan[]
  monthly_portfolio_items MonthlyPortfolioItem[]
  annual_commercial_plan_learning_sets AnnualCommercialPlanLearningSet[]
  commercial_plan_hierarchy_assignments     CommercialPlanHierarchyAssignment[]
  commercial_plan_event_links               CommercialPlanEventLink[]
  commercial_plan_campaign_links            CommercialPlanCampaignLink[]
  commercial_plan_learning_influences       CommercialPlanLearningInfluence[]
  commercial_budget_allocations             CommercialBudgetAllocation[]
  commercial_budget_ledger_entries          CommercialBudgetLedgerEntry[]
  commercial_assessment_signals CommercialAssessmentSignal[]
  commercial_historical_assessment_runs CommercialHistoricalAssessmentRun[]
  commercial_historical_assessment_evidence CommercialHistoricalAssessmentEvidence[]
  commercial_historical_assessment_findings CommercialHistoricalAssessmentFinding[]
  commercial_learning_sets CommercialLearningSet[]
  commercial_discipline_records CommercialDisciplineRecord[]
  commercial_executive_reports CommercialExecutiveReport[]
  commercial_executive_report_schedules CommercialExecutiveReportSchedule[]
  subscriptions TenantSubscription[]
  subscription_events TenantSubscriptionEvent[]
  stitchi_conversations StitchiConversation[]
  stitchi_messages StitchiMessage[]
  stitchi_action_runs StitchiActionRun[]
  stitchi_action_approvals StitchiActionApproval[]

  @@map("tenants")
}

model TenantPlan {
  id                 String           @id @default(uuid()) @db.Uuid
  plan_key           String           @unique
  name               String
  description        String?          @db.Text
  status             TenantPlanStatus @default(active)
  billing_interval   String           @default("monthly")
  currency           String           @default("USD")
  monthly_price_cents Int?
  annual_price_cents  Int?
  entitlements       Json
  created_at         DateTime         @default(now())
  updated_at         DateTime         @updatedAt

  subscriptions TenantSubscription[]

  @@index([status])
  @@map("tenant_plans")
}

model TenantSubscription {
  id                        String                   @id @default(uuid()) @db.Uuid
  tenant_key                String
  plan_id                   String                   @db.Uuid
  status                    TenantSubscriptionStatus @default(trialing)
  source                    TenantSubscriptionSource @default(manual)
  is_current                Boolean                  @default(true)
  external_customer_ref     String?
  external_subscription_ref String?
  trial_ends_at             DateTime?
  current_period_start      DateTime?
  current_period_end        DateTime?
  cancel_at                 DateTime?
  cancelled_at              DateTime?
  entitlements_override     Json?
  notes                     String?                  @db.Text
  created_at                DateTime                 @default(now())
  updated_at                DateTime                 @updatedAt

  tenant Tenant @relation(fields: [tenant_key], references: [tenant_key])
  plan   TenantPlan @relation(fields: [plan_id], references: [id])
  events TenantSubscriptionEvent[]

  @@index([tenant_key])
  @@index([plan_id])
  @@index([status])
  @@index([is_current])
  @@index([current_period_end])
  @@map("tenant_subscriptions")
}

model TenantSubscriptionEvent {
  id              String   @id @default(uuid()) @db.Uuid
  tenant_key      String
  subscription_id String   @db.Uuid
  event_type      String
  actor_user_id   String?  @db.Uuid
  reason          String?  @db.Text
  before_state    Json?
  after_state     Json?
  created_at      DateTime @default(now())

  tenant       Tenant             @relation(fields: [tenant_key], references: [tenant_key])
  subscription TenantSubscription @relation(fields: [subscription_id], references: [id])
  actor        User?              @relation(fields: [actor_user_id], references: [id])

  @@index([tenant_key])
  @@index([subscription_id])
  @@index([event_type])
  @@index([actor_user_id])
  @@index([created_at])
  @@map("tenant_subscription_events")
}

model TenantMembership {
  id          String   @id @default(uuid()) @db.Uuid
  tenant_key  String
  user_id     String   @db.Uuid
  role        Role
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenant_key], references: [tenant_key])
  user   User   @relation(fields: [user_id], references: [id])

  @@unique([tenant_key, user_id])
  @@index([tenant_key])
  @@index([user_id])
  @@map("tenant_memberships")
}

model Department {
  id                  String   @id @default(uuid()) @db.Uuid
  name                String   @unique
  description         String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  users User[]

  @@map("departments")
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  name          String
  password_hash String
  department_id String?  @db.Uuid
  tenant_key    String   @default("default")
  role          Role     @default(reviewer)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  department              Department?              @relation(fields: [department_id], references: [id])
  content_requests        ContentRequest[]
  approval_events         ApprovalEvent[]
  agent_reps              AgentRep[]
  decisions_as_human      SaifDecisionRecord[]     @relation("DecisionHumanUser")
  decisions_as_authority  SaifDecisionRecord[]     @relation("DecisionAuthorityUser")
  role_assignments_as_human DecisionRoleAssignment[] @relation("RoleHumanUser")
  approvals_as_requester  Approval[]               @relation("ApprovalRequesterUser")
  approvals_as_approver   Approval[]               @relation("ApprovalApproverUser")
  intents_created         Intent[]
  resolutions             CapabilityResolution[]
  mcp_mediation_requests  McpMediationRequest[]
  mcp_decisions_made      McpMediationDecision[]
  spine_runs              SpineRun[]
  spine_artifacts_created SpineArtifact[]
  assets_created          Asset[]
  asset_lineage_created   AssetLineage[]
  llm_provider_credentials LlmProviderCredential[]
  integration_credentials_created IntegrationCredential[]
  onboarding_tokens UserOnboardingToken[]
  mfa_factors UserMfaFactor[]
  mfa_recovery_codes UserMfaRecoveryCode[]
  tenant_memberships TenantMembership[]
  social_account_connections SocialAccountConnection[]
  oauth_connection_states OAuthConnectionState[]
  langgraph_workflows LangGraphWorkflow[]
  commercial_workflow_runs CommercialWorkflowRun[] @relation("CommercialWorkflowRunUser")
  commercial_events_owned CommercialEvent[]
  event_email_plans_created EventEmailPlan[]
  event_whatsapp_plans_created EventWhatsappPlan[]
  event_upsell_plans_created EventUpsellPlan[]
  event_content_requirements_created EventContentRequirement[]
  event_sales_tasks_created EventSalesTask[]
  lead_lifecycle_events LeadLifecycleEvent[]
  ghl_lead_sync_runs GhlLeadSyncRun[] @relation("GhlLeadSyncRunCreatedBy")
  event_problems_created EventProblem[] @relation("EventProblemCreatedBy")
  event_problems_resolved EventProblem[] @relation("EventProblemResolvedBy")
  connector_imports_created ConnectorImportJob[] @relation("ConnectorImportCreatedBy")
  connector_imports_approved ConnectorImportJob[] @relation("ConnectorImportApprovedBy")
  connector_field_mappings ConnectorFieldMapping[] @relation("ConnectorFieldMappingCreatedBy")
  commercial_revenue_lines_owned CommercialRevenueLine[] @relation("CommercialRevenueLineOwner")
  commercial_revenue_lines_created CommercialRevenueLine[] @relation("CommercialRevenueLineCreatedBy")
  commercial_plans_owned CommercialPlan[] @relation("CommercialPlanOwner")
  commercial_plans_created CommercialPlan[] @relation("CommercialPlanCreatedBy")
  annual_commercial_plans_owned AnnualCommercialPlan[] @relation("AnnualCommercialPlanOwner")
  annual_commercial_plans_created AnnualCommercialPlan[] @relation("AnnualCommercialPlanCreatedBy")
  annual_commercial_plans_submitted AnnualCommercialPlan[] @relation("AnnualCommercialPlanSubmittedBy")
  annual_commercial_plans_approved AnnualCommercialPlan[] @relation("AnnualCommercialPlanApprovedBy")
  monthly_portfolio_items_owned MonthlyPortfolioItem[] @relation("MonthlyPortfolioItemOwner")
  monthly_portfolio_items_created MonthlyPortfolioItem[] @relation("MonthlyPortfolioItemCreatedBy")
  commercial_hierarchy_links_created                CommercialPlanHierarchyAssignment[]     @relation("CommercialPlanHierarchyLinkedBy")
  commercial_hierarchy_exceptions_approved          CommercialPlanHierarchyAssignment[]     @relation("CommercialPlanHierarchyExceptionApprovedBy")
  commercial_event_links_created                    CommercialPlanEventLink[]               @relation("CommercialPlanEventLinkCreatedBy")
  commercial_event_link_exceptions_approved         CommercialPlanEventLink[]               @relation("CommercialPlanEventLinkExceptionApprovedBy")
  commercial_campaign_links_created                 CommercialPlanCampaignLink[]            @relation("CommercialPlanCampaignLinkCreatedBy")
  commercial_campaign_link_exceptions_approved      CommercialPlanCampaignLink[]            @relation("CommercialPlanCampaignLinkExceptionApprovedBy")
  commercial_learning_influences_created            CommercialPlanLearningInfluence[]       @relation("CommercialPlanLearningInfluenceCreatedBy")
  commercial_assessment_signals_created CommercialAssessmentSignal[] @relation("CommercialAssessmentSignalCreatedBy")
  commercial_historical_assessment_runs_requested CommercialHistoricalAssessmentRun[] @relation("CommercialHistoricalAssessmentRunRequestedBy")
  commercial_historical_assessment_findings_decided CommercialHistoricalAssessmentFinding[] @relation("CommercialHistoricalAssessmentFindingDecidedBy")
  commercial_learning_sets_approved CommercialLearningSet[] @relation("CommercialLearningSetApprovedBy")
  commercial_discipline_records_owned CommercialDisciplineRecord[] @relation("CommercialDisciplineRecordOwner")
  commercial_discipline_records_created CommercialDisciplineRecord[] @relation("CommercialDisciplineRecordCreatedBy")
  commercial_executive_reports_generated CommercialExecutiveReport[] @relation("CommercialExecutiveReportGeneratedBy")
  commercial_executive_report_schedules_created CommercialExecutiveReportSchedule[] @relation("CommercialExecutiveReportScheduleCreatedBy")
  tenant_subscription_events TenantSubscriptionEvent[]
  stitchi_conversations StitchiConversation[] @relation("StitchiConversationUser")
  stitchi_action_runs StitchiActionRun[] @relation("StitchiActionRunUser")
  stitchi_action_approvals StitchiActionApproval[] @relation("StitchiActionApprovalUser")

  tenant Tenant @relation(fields: [tenant_key], references: [tenant_key])
  @@map("users")
  @@index([tenant_key])
}

enum OnboardingTokenPurpose {
  invite
  password_reset
}

model UserOnboardingToken {
  id          String                 @id @default(uuid()) @db.Uuid
  user_id     String                 @db.Uuid
  purpose     OnboardingTokenPurpose
  token_hash  String                 @unique
  expires_at  DateTime
  used_at     DateTime?
  created_at  DateTime               @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([purpose])
  @@index([expires_at])
  @@map("user_onboarding_tokens")
}

enum MfaFactorType {
  totp
}

model UserMfaFactor {
  id               String        @id @default(uuid()) @db.Uuid
  user_id          String        @db.Uuid
  factor_type      MfaFactorType @default(totp)
  encrypted_secret String        @db.Text
  secret_fingerprint String
  label            String?
  is_verified      Boolean       @default(false)
  enabled_at       DateTime?
  disabled_at      DateTime?
  last_used_at     DateTime?
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([is_verified])
  @@map("user_mfa_factors")
}

model UserMfaRecoveryCode {
  id          String    @id @default(uuid()) @db.Uuid
  user_id     String    @db.Uuid
  code_hash   String    @unique
  used_at     DateTime?
  created_at  DateTime  @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id])
  @@index([used_at])
  @@map("user_mfa_recovery_codes")
}

enum LlmProviderType {
  openai
  claude
  deepseek
  gemma
}

model LlmProviderCredential {
  id                String          @id @default(uuid()) @db.Uuid
  owner_user_id     String          @db.Uuid
  provider          LlmProviderType
  model             String
  encrypted_api_key String          @db.Text
  key_fingerprint   String
  is_active         Boolean         @default(true)
  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt
  last_used_at      DateTime?

  owner User @relation(fields: [owner_user_id], references: [id])

  @@unique([owner_user_id, provider])
  @@index([owner_user_id])
  @@map("llm_provider_credentials")
}

model IntegrationCredential {
  id                  String   @id @default(uuid()) @db.Uuid
  tenant_key          String   @default("default")
  provider            String
  credential_type     String
  connection_key      String   @default("default")
  display_name        String
  encrypted_payload   Json
  secret_fingerprints Json
  metadata            Json?
  created_by_user_id  String   @db.Uuid
  is_active           Boolean  @default(true)
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
  last_validated_at   DateTime?

  created_by User @relation(fields: [created_by_user_id], references: [id])

  @@unique([tenant_key, provider, credential_type, connection_key])
  @@index([tenant_key])
  @@index([provider])
  @@index([connection_key])
  @@index([is_active])
  @@map("integration_credentials")
}

enum SocialConnectionStatus {
  connected
  expired
  revoked
  failed
}

model OAuthConnectionState {
  id                 String   @id @default(uuid()) @db.Uuid
  tenant_key         String
  platform           String
  state_hash         String   @unique
  redirect_uri       String
  requested_scopes   String[]
  requester_user_id  String   @db.Uuid
  code_verifier      String?
  expires_at         DateTime
  used_at            DateTime?
  created_at         DateTime @default(now())

  requester User @relation(fields: [requester_user_id], references: [id])

  @@index([tenant_key])
  @@index([platform])
  @@index([expires_at])
  @@map("oauth_connection_states")
}

model SocialAccountConnection {
  id                      String                 @id @default(uuid()) @db.Uuid
  tenant_key              String
  platform                String
  account_id              String
  account_name            String?
  scopes                  String[]
  encrypted_access_token  String                 @db.Text
  encrypted_refresh_token String?                @db.Text
  token_expires_at        DateTime?
  status                  SocialConnectionStatus @default(connected)
  connected_by_user_id    String                 @db.Uuid
  metadata                Json?
  connected_at            DateTime               @default(now())
  updated_at              DateTime               @updatedAt

  connected_by User @relation(fields: [connected_by_user_id], references: [id])

  @@unique([tenant_key, platform, account_id])
  @@index([tenant_key])
  @@index([platform])
  @@index([status])
  @@map("social_account_connections")
}

enum LangGraphWorkflowStatus {
  running
  interrupted
  completed
  failed
}

enum StitchiConversationStatus {
  active
  archived
}

enum StitchiMessageRole {
  user
  assistant
  system
}

enum StitchiActionRunStatus {
  proposed
  awaiting_approval
  approved
  rejected
  running
  completed
  failed
  cancelled
}

enum StitchiActionRiskLevel {
  low
  medium
  high
}

enum StitchiApprovalDecision {
  approved
  rejected
  changes_requested
}

model LangGraphWorkflow {
  id                  String                  @id @default(uuid()) @db.Uuid
  thread_id           String                  @unique
  tenant_key          String
  workflow_type       String
  status              LangGraphWorkflowStatus @default(running)
  human_user_id       String                  @db.Uuid
  checkpoint_strategy String                  @default("database_state_snapshot")
  state_snapshot      Json
  interrupt_payload   Json?
  result_payload      Json?
  created_at          DateTime                @default(now())
  updated_at          DateTime                @updatedAt
  completed_at        DateTime?

  human_user User @relation(fields: [human_user_id], references: [id])

  @@index([tenant_key])
  @@index([workflow_type])
  @@index([status])
  @@map("langgraph_workflows")
}

model StitchiConversation {
  id         String                    @id @default(uuid()) @db.Uuid
  tenant_key String
  user_id    String                    @db.Uuid
  event_id   String?                   @db.Uuid
  title      String
  status     StitchiConversationStatus @default(active)
  created_at DateTime                  @default(now())
  updated_at DateTime                  @updatedAt

  tenant      Tenant           @relation(fields: [tenant_key], references: [tenant_key])
  user        User             @relation("StitchiConversationUser", fields: [user_id], references: [id])
  event       CommercialEvent? @relation(fields: [event_id], references: [id], onDelete: SetNull)
  messages    StitchiMessage[]
  action_runs StitchiActionRun[]

  @@index([tenant_key])
  @@index([user_id])
  @@index([event_id])
  @@index([status])
  @@map("stitchi_conversations")
}

model StitchiMessage {
  id              String             @id @default(uuid()) @db.Uuid
  tenant_key      String
  conversation_id String             @db.Uuid
  role            StitchiMessageRole @default(user)
  content         String             @db.Text
  metadata        Json?
  created_at      DateTime           @default(now())

  tenant       Tenant              @relation(fields: [tenant_key], references: [tenant_key])
  conversation StitchiConversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@index([tenant_key])
  @@index([conversation_id])
  @@index([role])
  @@index([created_at])
  @@map("stitchi_messages")
}

model StitchiActionRun {
  id                  String                 @id @default(uuid()) @db.Uuid
  tenant_key          String
  conversation_id     String                 @db.Uuid
  user_id             String                 @db.Uuid
  action_type         String
  status              StitchiActionRunStatus @default(proposed)
  input_payload       Json
  preview_payload     Json?
  result_payload      Json?
  requires_approval   Boolean                @default(false)
  risk_level          StitchiActionRiskLevel @default(low)
  audit_record_id     String?                @db.Uuid
  langgraph_thread_id String?
  created_at          DateTime               @default(now())
  updated_at          DateTime               @updatedAt
  completed_at        DateTime?

  tenant       Tenant                  @relation(fields: [tenant_key], references: [tenant_key])
  conversation StitchiConversation     @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  user         User                    @relation("StitchiActionRunUser", fields: [user_id], references: [id])
  approvals    StitchiActionApproval[]

  @@index([tenant_key])
  @@index([conversation_id])
  @@index([user_id])
  @@index([action_type])
  @@index([status])
  @@map("stitchi_action_runs")
}

model StitchiActionApproval {
  id             String                  @id @default(uuid()) @db.Uuid
  tenant_key     String
  action_run_id  String                  @db.Uuid
  approver_user_id String                @db.Uuid
  decision       StitchiApprovalDecision
  notes          String?                 @db.Text
  created_at     DateTime                @default(now())

  tenant     Tenant           @relation(fields: [tenant_key], references: [tenant_key])
  action_run StitchiActionRun @relation(fields: [action_run_id], references: [id], onDelete: Cascade)
  approver   User             @relation("StitchiActionApprovalUser", fields: [approver_user_id], references: [id])

  @@index([tenant_key])
  @@index([action_run_id])
  @@index([approver_user_id])
  @@index([decision])
  @@map("stitchi_action_approvals")
}

model AgentRep {
  id                   String      @id @default(uuid()) @db.Uuid
  user_id              String      @unique @db.Uuid
  name                 String
  agent_type           AgentType   @default(functional)
  status               AgentStatus @default(active)
  permissions_context  Json?
  metadata             Json?
  created_at           DateTime    @default(now())
  updated_at           DateTime    @updatedAt

  user                     User                       @relation(fields: [user_id], references: [id])
  functional_agents        FunctionalAgent[]
  governance_agents        GovernanceAgent[]
  decisions_as_rep         SaifDecisionRecord[]       @relation("DecisionAgentRep")
  decisions_as_authority   SaifDecisionRecord[]       @relation("DecisionAuthorityAgentRep")
  role_assignments_as_agent DecisionRoleAssignment[]  @relation("RoleAgentRep")
  handoffs                 DecisionExecutionHandoff[] @relation("HandoffAgentRep")
  approvals_as_requester   Approval[]                 @relation("ApprovalRequesterAgentRep")
  approvals_as_approver    Approval[]                 @relation("ApprovalApproverAgentRep")
  intents_created          Intent[]
  resolutions              CapabilityResolution[]
  mcp_mediation_requests   McpMediationRequest[]
  mcp_decisions_made       McpMediationDecision[]
  spine_runs               SpineRun[]
  spine_artifacts_created  SpineArtifact[]
  assets_created           Asset[]
  asset_lineage_created    AssetLineage[]
  commercial_workflow_runs CommercialWorkflowRun[] @relation("CommercialWorkflowRunAgentRep")

  @@map("agent_reps")
}

model FunctionalAgent {
  id            String      @id @default(uuid()) @db.Uuid
  agent_rep_id  String      @db.Uuid
  name          String
  description   String?
  capability    String
  status        AgentStatus @default(active)
  config        Json?
  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt

  agent_rep        AgentRep                  @relation(fields: [agent_rep_id], references: [id])
  role_assignments DecisionRoleAssignment[]

  @@map("functional_agents")
}

model GovernanceAgent {
  id             String      @id @default(uuid()) @db.Uuid
  agent_rep_id   String      @db.Uuid
  name           String
  description    String?
  policy_scope   String[]
  veto_authority Boolean     @default(false)
  status         AgentStatus @default(active)
  config         Json?
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt

  agent_rep        AgentRep                  @relation(fields: [agent_rep_id], references: [id])
  role_assignments DecisionRoleAssignment[]

  @@map("governance_agents")
}

// ============================================================
// Content & Campaigns
// ============================================================

enum ContentType {
  campaign
  announcement
  thought_leadership
  product_update
  hiring
  event
  evergreen
  reactive
}

enum RiskCategory {
  low
  medium
  high
}

enum ContentState {
  idea
  drafting
  pending_review
  needs_edits
  approved
  scheduled
  published
  analytics_pending
  analyzed
  archived
  recycle_candidate
  failed
  expired
  rejected
