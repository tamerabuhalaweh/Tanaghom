  @@index([revenue_line_id])
  @@index([status])
  @@index([date_from, date_to])
  @@index([requested_by_user_id])
  @@map("commercial_historical_assessment_runs")
}

model CommercialHistoricalAssessmentEvidence {
  id                 String                                     @id @default(uuid()) @db.Uuid
  tenant_key         String
  assessment_run_id  String                                     @db.Uuid
  evidence_type      CommercialHistoricalAssessmentEvidenceType
  source_object_type String
  source_object_id   String
  source_name        String?
  metric_key         String
  metric_value       Decimal?                                   @db.Decimal(16, 4)
  metric_unit        String?
  observed_at        DateTime?
  payload            Json?
  created_at         DateTime                                   @default(now())

  tenant         Tenant                            @relation(fields: [tenant_key], references: [tenant_key])
  assessment_run CommercialHistoricalAssessmentRun @relation(fields: [assessment_run_id], references: [id], onDelete: Cascade)

  @@unique([assessment_run_id, evidence_type, source_object_type, source_object_id, metric_key])
  @@index([tenant_key])
  @@index([assessment_run_id])
  @@index([evidence_type])
  @@index([source_object_type, source_object_id])
  @@map("commercial_historical_assessment_evidence")
}

model CommercialHistoricalAssessmentFinding {
  id                 String                                        @id @default(uuid()) @db.Uuid
  tenant_key         String
  assessment_run_id  String                                        @db.Uuid
  learning_set_id    String?                                       @db.Uuid
  finding_type       CommercialHistoricalAssessmentFindingType
  title              String
  summary            String                                        @db.Text
  recommendation     String                                        @db.Text
