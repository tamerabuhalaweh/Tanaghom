  supports_read      Boolean            @default(true)
  supports_write     Boolean            @default(false)
  m4_allowed         Boolean            @default(true)
  m5_allowed         Boolean            @default(false)
  credential_required Boolean           @default(true)
  owner_substrate    String?
  created_at         DateTime           @default(now())
  updated_at         DateTime           @updatedAt

  capability_bindings McpCapabilityBinding[]
  mediation_requests  McpMediationRequest[]
  credential_bindings McpCredentialBinding[]
  discovered_tools    McpDiscoveredTool[]

  @@index([status])
  @@index([connector_type])
  @@map("mcp_connectors")
}

model McpDiscoveredTool {
  id               String   @id @default(uuid()) @db.Uuid
  mcp_connector_id String   @db.Uuid
