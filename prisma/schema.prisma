  saif_decision_record_id String?      @db.Uuid
  human_user_id         String         @db.Uuid
  agent_rep_id          String         @db.Uuid
  resolution_status     ResolutionStatus @default(pending)
  rationale             String?        @db.Text
  constraints_applied   Json?
  rejected_alternatives Json?
  created_at            DateTime       @default(now())
  updated_at            DateTime       @updatedAt

  intent            Intent             @relation(fields: [intent_id], references: [id])
  objective         Objective          @relation(fields: [objective_id], references: [id])
  capability        Capability         @relation(fields: [capability_id], references: [id])
  execution_pattern ExecutionPattern    @relation(fields: [execution_pattern_id], references: [id])
  implementation    Implementation     @relation(fields: [implementation_id], references: [id])
  saif_decision     SaifDecisionRecord? @relation(fields: [saif_decision_record_id], references: [id])
  human_user        User               @relation(fields: [human_user_id], references: [id])
