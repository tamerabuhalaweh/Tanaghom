}

model McpMediationDecision {
  id                    String               @id @default(uuid()) @db.Uuid
  mediation_request_id  String               @db.Uuid
  decision              McpMediationDecisionType
  rationale             String?              @db.Text
  policy_matched        String?
  decided_by_user_id    String?              @db.Uuid
  decided_by_agent_rep_id String?            @db.Uuid
  decided_at            DateTime             @default(now())
  created_at            DateTime             @default(now())

  mediation_request     McpMediationRequest  @relation(fields: [mediation_request_id], references: [id])
  decided_by_user       User?                @relation(fields: [decided_by_user_id], references: [id])
