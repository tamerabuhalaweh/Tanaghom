// ============================================================
// Event Problem & Barrier Log — Sprint 63C
// ============================================================

enum ProblemCategory {
  content
  ads
  audience
  funnel
  sales
  budget
  operations
  integration
  other
}

enum ProblemSeverity {
  low
  medium
  high
  critical
}

enum ProblemStatus {
  open
  investigating
  resolved
  dismissed
}

enum ProblemSource {
  manual
  kpi_review
  lead_review
  sales_feedback
  campaign_review
  integration_check
}

model EventProblem {
  id                  String           @id @default(uuid()) @db.Uuid
  tenant_key          String
  event_id            String           @db.Uuid
  title               String           @db.Text
  description         String?          @db.Text
  category            ProblemCategory
  severity            ProblemSeverity  @default(medium)
  status              ProblemStatus    @default(open)
  source              ProblemSource    @default(manual)
  impact_summary      String?          @db.Text
  recommended_action  String?          @db.Text
  owner_role          String?
  related_lead_id     String?          @db.Uuid
  related_campaign_id String?          @db.Uuid
  due_date            DateTime?
  resolution_notes    String?          @db.Text
  created_by_user_id  String           @db.Uuid
  resolved_by_user_id String?          @db.Uuid
  resolved_at         DateTime?
  created_at          DateTime         @default(now())
  updated_at          DateTime         @updatedAt

  tenant      Tenant          @relation(fields: [tenant_key], references: [tenant_key])
  event       CommercialEvent @relation(fields: [event_id], references: [id])
  created_by  User            @relation("EventProblemCreatedBy", fields: [created_by_user_id], references: [id])
  resolved_by User?           @relation("EventProblemResolvedBy", fields: [resolved_by_user_id], references: [id])

  @@index([tenant_key])
  @@index([event_id])
  @@index([status])
  @@index([severity])
  @@index([category])
  @@index([created_by_user_id])
  @@map("event_problems")
}

// ============================================================
// Connector Import Jobs — Sprint 64
// ============================================================

enum ConnectorImportState {
  draft
  requires_credentials
  ready_for_test
  test_passed
  blocked
  disabled
}

enum ConnectorCredentialState {
  customer_credential_missing
  configured
  test_not_run
  test_passed
  blocked_by_provider_approval
}

enum ConnectorSyncStatus {
  not_started
  requires_credentials
  ready_for_sync
  synced
  failed
  blocked
}

model ConnectorImportJob {
  id                  String                  @id @default(uuid()) @db.Uuid
  tenant_key          String
  event_id            String?                 @db.Uuid
  mapping_id          String?                 @db.Uuid
  connector_id        String
  display_name        String
  state               ConnectorImportState   @default(draft)
  credential_state    ConnectorCredentialState @default(customer_credential_missing)
  notes               String?                @db.Text
  last_dry_run_at     DateTime?
  last_dry_run_result Json?
  sync_status         ConnectorSyncStatus    @default(not_started)
  last_sync_at        DateTime?
  last_sync_rows      Int                    @default(0)
  last_sync_error     String?                @db.Text
  last_sync_audit_record_id String?          @db.Uuid
  last_import_at      DateTime?
  last_import_result  Json?
  approved_by_user_id String?                @db.Uuid
  approved_at         DateTime?
  disabled_at         DateTime?
  disabled_reason     String?                @db.Text
  created_by_user_id  String                 @db.Uuid
  created_at          DateTime               @default(now())
  updated_at          DateTime               @updatedAt

  tenant       Tenant          @relation(fields: [tenant_key], references: [tenant_key])
  event        CommercialEvent? @relation(fields: [event_id], references: [id])
  field_mapping ConnectorFieldMapping? @relation(fields: [mapping_id], references: [id])
  created_by   User            @relation("ConnectorImportCreatedBy", fields: [created_by_user_id], references: [id])
  approved_by  User?           @relation("ConnectorImportApprovedBy", fields: [approved_by_user_id], references: [id])
  kpi_records   EventKpiRecord[]

  @@index([tenant_key])
  @@index([event_id])
  @@index([mapping_id])
  @@index([connector_id])
  @@index([state])
  @@index([sync_status])
  @@index([last_sync_at])
  @@index([created_by_user_id])
  @@map("connector_import_jobs")
}

// ============================================================
// Connector Field Mapping — Sprint 64B
// ============================================================

enum MappingTargetType {
  event_kpi_record
}

enum MappingValidationStatus {
  valid
  invalid
  untested
}

model ConnectorFieldMapping {
  id                  String                  @id @default(uuid()) @db.Uuid
  tenant_key          String
  connector_id        String
  event_id            String?                 @db.Uuid
  display_name        String
  target_type         MappingTargetType       @default(event_kpi_record)
  field_mappings      Json
  validation_status   MappingValidationStatus @default(untested)
  validation_errors   Json?
  created_by_user_id  String                  @db.Uuid
  created_at          DateTime                @default(now())
  updated_at          DateTime                @updatedAt

  tenant      Tenant @relation(fields: [tenant_key], references: [tenant_key])
  event       CommercialEvent? @relation(fields: [event_id], references: [id])
  created_by  User   @relation("ConnectorFieldMappingCreatedBy", fields: [created_by_user_id], references: [id])
  connector_import_jobs ConnectorImportJob[]

  @@index([tenant_key])
  @@index([connector_id])
  @@index([event_id])
  @@index([created_by_user_id])
  @@map("connector_field_mappings")
}
