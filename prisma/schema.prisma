model CommercialRevenueLine {
  id                 String                      @id @default(uuid()) @db.Uuid
  tenant_key         String
  revenue_line_type  CommercialRevenueLineType
  name               String
  description        String?                     @db.Text
  status             CommercialRevenueLineStatus @default(active)
  system_of_record   String                      @default("tanaghum")
  owner_user_id      String?                     @db.Uuid
  created_by_user_id String                      @db.Uuid
  created_at         DateTime                    @default(now())
  updated_at         DateTime                    @updatedAt

  tenant             Tenant                      @relation(fields: [tenant_key], references: [tenant_key])
  owner              User?                       @relation("CommercialRevenueLineOwner", fields: [owner_user_id], references: [id])
  created_by         User                        @relation("CommercialRevenueLineCreatedBy", fields: [created_by_user_id], references: [id])
  plans              CommercialPlan[]
  monthly_portfolio_items MonthlyPortfolioItem[]
  assessment_signals CommercialAssessmentSignal[]
  historical_assessment_runs CommercialHistoricalAssessmentRun[]
  discipline_records CommercialDisciplineRecord[]

  @@unique([tenant_key, revenue_line_type])
  @@index([tenant_key])
  @@index([revenue_line_type])
  @@index([status])
  @@index([owner_user_id])
  @@map("commercial_revenue_lines")
}

model CommercialPlan {
  id                 String                   @id @default(uuid()) @db.Uuid
  tenant_key         String
  revenue_line_id    String                   @db.Uuid
  linked_event_id    String?                  @db.Uuid
  horizon            CommercialPlanHorizon
  stage              CommercialOperatingStage @default(strategy_planning)
  title              String
  objective          String?                  @db.Text
  audience           String?                  @db.Text
  currency           CommercialCurrency       @default(AED)
  budget_target      Decimal?                 @db.Decimal(12, 2)
  revenue_target     Decimal?                 @db.Decimal(12, 2)
  kpi_targets        Json?
  strategy_summary   String?                  @db.Text
  action_plan        String?                  @db.Text
  status             CommercialPlanStatus     @default(draft)
  origin             CommercialPlanOrigin     @default(legacy_unclassified)
  standalone_reason  String?                  @db.Text
  owner_user_id      String?                  @db.Uuid
  superseded_by_plan_id String?                  @db.Uuid
  superseded_at         DateTime?
  superseded_reason     String?                  @db.Text
  created_by_user_id String                   @db.Uuid
  created_at         DateTime                 @default(now())
  updated_at         DateTime                 @updatedAt

  tenant             Tenant                   @relation(fields: [tenant_key], references: [tenant_key])
  revenue_line       CommercialRevenueLine    @relation(fields: [revenue_line_id], references: [id], onDelete: Cascade)
  linked_event       CommercialEvent?         @relation(fields: [linked_event_id], references: [id], onDelete: SetNull)
  owner              User?                    @relation("CommercialPlanOwner", fields: [owner_user_id], references: [id])
  created_by         User                     @relation("CommercialPlanCreatedBy", fields: [created_by_user_id], references: [id])
  superseded_by           CommercialPlan?                    @relation("CommercialPlanSupersession", fields: [superseded_by_plan_id], references: [id], onDelete: SetNull)
  supersedes              CommercialPlan[]                   @relation("CommercialPlanSupersession")
  assessment_signals CommercialAssessmentSignal[]
  discipline_records CommercialDisciplineRecord[]
  monthly_portfolio_items MonthlyPortfolioItem[]
  hierarchy_assignment    CommercialPlanHierarchyAssignment?
  event_links             CommercialPlanEventLink[]
  campaign_links          CommercialPlanCampaignLink[]
  learning_influences     CommercialPlanLearningInfluence[]
  budget_allocations      CommercialBudgetAllocation[]

  @@index([tenant_key])
  @@index([revenue_line_id])
  @@index([linked_event_id])
  @@index([horizon])
  @@index([stage])
  @@index([status])
  @@index([origin])
  @@index([owner_user_id])
  @@index([superseded_by_plan_id])
  @@map("commercial_plans")
}

model CommercialAssessmentSignal {
