  execution
}

enum SpineRunStatus {
  planned
  ready
  simulated
  running
  succeeded
  failed
  cancelled
  blocked
  audited
}

enum SpineReplayStatus {
  replayable
  partial
  not_replayable
}

enum SpineArtifactType {
  campaign_request_snapshot
  draft_version_snapshot
  reach_score_report
  approval_record_snapshot
  saif_decision_record
  dks_reference_bundle
  capability_resolution_bundle
