enum McpConnectorStatus {
  active
  inactive
  suspended
  planned
}

enum McpMediationRequestStatus {
  pending
  approved
  denied
  deferred
  escalated
  blocked
}

enum McpMediationDecisionType {
  allow
  deny
  defer
  escalate
  blocked_m5
  blocked_missing_approval
  blocked_missing_saif
  blocked_direct_access
  blocked_inactive_connector
  blocked_suspended_credential
