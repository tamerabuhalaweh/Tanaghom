  @@map("crm_handoff_requests")
}

model WhatsAppHandoffRequest {
  id                       String         @id @default(uuid()) @db.Uuid
  lead_capture_record_id   String         @db.Uuid
  messaging_system         String
  mcp_mediation_request_id String?        @db.Uuid
  approval_id              String?        @db.Uuid
  capability_resolution_id String?        @db.Uuid
  requested_by_user_id     String         @db.Uuid
  requested_by_agent_rep_id String        @db.Uuid
  handoff_status           HandoffStatus  @default(pending)
  message_template_summary String?        @db.Text
  payload_hash             String?
  blocked_reason           String?        @db.Text
  created_at               DateTime       @default(now())
  updated_at               DateTime       @updatedAt

  lead_capture_record LeadCaptureRecord @relation(fields: [lead_capture_record_id], references: [id])

  @@index([lead_capture_record_id])
  @@index([handoff_status])
  @@map("whatsapp_handoff_requests")
}

model ConversionSequencePlan {
  id                         String     @id @default(uuid()) @db.Uuid
  lead_capture_record_id     String     @db.Uuid
  conversion_intent_id       String?    @db.Uuid
  plan_status                PlanStatus @default(draft)
  sequence_type              String
  proposed_steps             Json?
  recommended_owner_department String?
  required_approval_id       String?    @db.Uuid
  saif_decision_record_id    String?    @db.Uuid
  created_by_user_id         String     @db.Uuid
  created_by_agent_rep_id    String     @db.Uuid
  created_at                 DateTime   @default(now())
  updated_at                 DateTime   @updatedAt

  lead_capture_record LeadCaptureRecord @relation(fields: [lead_capture_record_id], references: [id])

  @@index([lead_capture_record_id])
  @@index([plan_status])
  @@index([sequence_type])
  @@map("conversion_sequence_plans")
}
