model CommercialHistoricalAssessmentRun {
  id                   String                                  @id @default(uuid()) @db.Uuid
  tenant_key           String
  revenue_line_id      String?                                 @db.Uuid
  event_ids            String[]                                @default([])
  campaign_ids         String[]                                @default([])
  audience_query       String?
  channels             String[]                                @default([])
  title                String
  date_from            DateTime
  date_to              DateTime
  status               CommercialHistoricalAssessmentRunStatus @default(draft)
  evidence_summary     Json?
  missing_data         Json?
  provider_type        String?
  provider_model       String?
  prompt_version       String                                  @default("commercial-historical-assessment.v1")
  requested_by_user_id String                                  @db.Uuid
  generated_at         DateTime?
  approved_at          DateTime?
  failure_reason       String?                                 @db.Text
  created_at           DateTime                                @default(now())
  updated_at           DateTime                                @updatedAt

  tenant            Tenant                                   @relation(fields: [tenant_key], references: [tenant_key])
  revenue_line      CommercialRevenueLine?                   @relation(fields: [revenue_line_id], references: [id], onDelete: SetNull)
  requested_by      User                                     @relation("CommercialHistoricalAssessmentRunRequestedBy", fields: [requested_by_user_id], references: [id])
  evidence          CommercialHistoricalAssessmentEvidence[]
  findings          CommercialHistoricalAssessmentFinding[]
