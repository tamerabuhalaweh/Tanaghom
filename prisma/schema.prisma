// Prisma Schema — Tanaghum AI Commercial Automation Platform
//
// PROVISIONAL DRAFT — This schema is a foundation draft based on DATA_MODEL.md.
// It is expected to evolve sprint by sprint as business modules are implemented.
// Each sprint will add, modify, or refine models and enums as needed.
// Do NOT treat this schema as final until all sprints are complete.
//
// Current status: Sprint 6 — SAIF Decision Records & DKS Foundation.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Auth & Users
// ============================================================

enum Role {
  admin
  cco
  department_head
  specialist
  reviewer
  viewer
}

enum AgentType {
  functional
  governance
}

enum AgentStatus {
  active
  inactive
  suspended
}

model Department {
  id                  String   @id @default(uuid()) @db.Uuid
  name                String   @unique
  description         String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  users User[]

  @@map("departments")
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String   @unique
  name          String
  password_hash String
  department_id String?  @db.Uuid
  role          Role     @default(reviewer)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  department              Department?              @relation(fields: [department_id], references: [id])
  content_requests        ContentRequest[]
  approval_events         ApprovalEvent[]
  agent_reps              AgentRep[]
  decisions_as_human      SaifDecisionRecord[]     @relation("DecisionHumanUser")
  decisions_as_authority  SaifDecisionRecord[]     @relation("DecisionAuthorityUser")
  role_assignments_as_human DecisionRoleAssignment[] @relation("RoleHumanUser")
  approvals_as_requester  Approval[]               @relation("ApprovalRequesterUser")
  approvals_as_approver   Approval[]               @relation("ApprovalApproverUser")
  intents_created         Intent[]
  resolutions             CapabilityResolution[]
  mcp_mediation_requests  McpMediationRequest[]
  mcp_decisions_made      McpMediationDecision[]
  spine_runs              SpineRun[]
  spine_artifacts_created SpineArtifact[]
  assets_created          Asset[]
  asset_lineage_created   AssetLineage[]

  @@map("users")
}

model AgentRep {
  id                   String      @id @default(uuid()) @db.Uuid
  user_id              String      @unique @db.Uuid
  name                 String
  agent_type           AgentType   @default(functional)
  status               AgentStatus @default(active)
  permissions_context  Json?
  metadata             Json?
  created_at           DateTime    @default(now())
  updated_at           DateTime    @updatedAt

  user                     User                       @relation(fields: [user_id], references: [id])
  functional_agents        FunctionalAgent[]
  governance_agents        GovernanceAgent[]
  decisions_as_rep         SaifDecisionRecord[]       @relation("DecisionAgentRep")
  decisions_as_authority   SaifDecisionRecord[]       @relation("DecisionAuthorityAgentRep")
  role_assignments_as_agent DecisionRoleAssignment[]  @relation("RoleAgentRep")
  handoffs                 DecisionExecutionHandoff[] @relation("HandoffAgentRep")
  approvals_as_requester   Approval[]                 @relation("ApprovalRequesterAgentRep")
  approvals_as_approver    Approval[]                 @relation("ApprovalApproverAgentRep")
  intents_created          Intent[]
  resolutions              CapabilityResolution[]
  mcp_mediation_requests   McpMediationRequest[]
  mcp_decisions_made       McpMediationDecision[]
  spine_runs               SpineRun[]
  spine_artifacts_created  SpineArtifact[]
  assets_created           Asset[]
  asset_lineage_created    AssetLineage[]

  @@map("agent_reps")
}

model FunctionalAgent {
  id            String      @id @default(uuid()) @db.Uuid
  agent_rep_id  String      @db.Uuid
  name          String
  description   String?
  capability    String
  status        AgentStatus @default(active)
  config        Json?
  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt

  agent_rep        AgentRep                  @relation(fields: [agent_rep_id], references: [id])
  role_assignments DecisionRoleAssignment[]

  @@map("functional_agents")
}

model GovernanceAgent {
  id             String      @id @default(uuid()) @db.Uuid
  agent_rep_id   String      @db.Uuid
  name           String
  description    String?
  policy_scope   String[]
  veto_authority Boolean     @default(false)
  status         AgentStatus @default(active)
  config         Json?
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt

  agent_rep        AgentRep                  @relation(fields: [agent_rep_id], references: [id])
  role_assignments DecisionRoleAssignment[]

  @@map("governance_agents")
}

// ============================================================
// Content & Campaigns
// ============================================================

enum ContentType {
  campaign
  announcement
  thought_leadership
  product_update
  hiring
  event
  evergreen
  reactive
}

enum RiskCategory {
  low
  medium
  high
}

enum ContentState {
  idea
  drafting
  pending_review
  needs_edits
  approved
  scheduled
  published
  analytics_pending
  analyzed
  archived
  recycle_candidate
  failed
  expired
  rejected
  cancelled
}

model ContentRequest {
  id                  String        @id @default(uuid()) @db.Uuid
  requester_id        String        @db.Uuid
  channel             String
  raw_message         String        @db.Text
  objective           String
  audience            String?
  campaign_id         String?       @db.Uuid
  owner_department_id String?       @db.Uuid
  content_type        ContentType   @default(campaign)
  risk_category       RiskCategory  @default(low)
  target_platforms    String[]
  deadline            DateTime?
  cta                 String?
  media_refs          Json?
  status              ContentState  @default(idea)
  created_at          DateTime      @default(now())
  updated_at          DateTime      @updatedAt

  requester     User           @relation(fields: [requester_id], references: [id])
  content_items ContentItem[]

  @@map("content_requests")
}

model ContentItem {
  id               String       @id @default(uuid()) @db.Uuid
  request_id       String       @db.Uuid
  platform         String
  content_type     String       @default("post")
  draft_text       String       @db.Text
  media_refs       Json?
  risk_score       Int          @default(0)
  risk_reason      String?
  reach_score      Int          @default(0)
  reach_breakdown  Json?
  status           ContentState @default(drafting)
  created_at       DateTime     @default(now())
  updated_at       DateTime     @updatedAt

  request          ContentRequest   @relation(fields: [request_id], references: [id])
  draft_versions   DraftVersion[]
  approval_events  ApprovalEvent[]
  schedule_events  ScheduleEvent[]

  @@map("content_items")
}

model DraftVersion {
  id              String   @id @default(uuid()) @db.Uuid
  content_item_id String   @db.Uuid
  version_no      Int
  text            String   @db.Text
  model_used      String?
  prompt_hash     String?
  created_at      DateTime @default(now())

  content_item ContentItem @relation(fields: [content_item_id], references: [id])

  @@map("draft_versions")
}

// ============================================================
// Approvals
// ============================================================

enum ApprovalDecision {
  approved
  rejected
  needs_changes
}

model ApprovalEvent {
  id              String           @id @default(uuid()) @db.Uuid
  content_item_id String           @db.Uuid
  reviewer_id     String           @db.Uuid
  department      String
  decision        ApprovalDecision
  comments        String?
  timestamp       DateTime         @default(now())

  content_item ContentItem @relation(fields: [content_item_id], references: [id])
  reviewer     User        @relation(fields: [reviewer_id], references: [id])

  @@map("approval_events")
}

// ============================================================
// Publishing
// ============================================================

enum ScheduleStatus {
  pending
  scheduled
  published
  failed
  cancelled
}

model ScheduleEvent {
  id              String         @id @default(uuid()) @db.Uuid
  content_item_id String         @db.Uuid
  postiz_post_id  String?
  integration_id  String?
  scheduled_at    DateTime
  timezone        String         @default("UTC")
  status          ScheduleStatus @default(pending)
  retry_count     Int            @default(0)
  last_error      String?
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  content_item ContentItem @relation(fields: [content_item_id], references: [id])

  @@map("schedule_events")
}

// ============================================================
// Analytics
// ============================================================

enum MetricWindow {
  h48
  d7
  d30
}

model AnalyticsSnapshot {
  id                      String   @id @default(uuid()) @db.Uuid
  source_id               String   @db.Uuid
  ingestion_request_id    String?  @db.Uuid
  campaign_id             String?  @db.Uuid
  content_item_id         String?  @db.Uuid
  publishing_package_id   String?  @db.Uuid
  postiz_publishing_job_id String? @db.Uuid
  platform                String?
  reporting_period_id     String?  @db.Uuid
  metrics                 Json
  normalized_metrics      Json
  confidence              String   @default("low")
  source_freshness        String?
  collected_at            DateTime @default(now())
  created_at              DateTime @default(now())

  source             AnalyticsSource           @relation(fields: [source_id], references: [id])
  ingestion_request  AnalyticsIngestionRequest? @relation(fields: [ingestion_request_id], references: [id])

  @@index([source_id])
  @@index([campaign_id])
  @@index([content_item_id])
  @@index([collected_at])
  @@map("analytics_snapshots")
}

// ============================================================
// Learning
// ============================================================

enum InsightType {
  content_type
  hook
  cta
  timing
  format
  topic
}

enum Confidence {
  low
  medium
  high
}

model LearningInsight {
  id                String      @id @default(uuid()) @db.Uuid
  platform          String
  insight_type      InsightType
  evidence_summary  String      @db.Text
  confidence        Confidence  @default(low)
  recommendation    String      @db.Text
  created_at        DateTime    @default(now())

  @@map("learning_insights")
}

// ============================================================
// Platform Rules
// ============================================================

enum SourceType {
  official_docs
  official_policy
  internal_benchmark
  team_decision
  third_party_research
  internal_analytics
}

model PlatformRule {
  id               String     @id @default(uuid()) @db.Uuid
  platform         String
  rule_type        String
  rule_value       String     @db.Text
  source_url       String?
  source_type      SourceType @default(team_decision)
  confidence       Confidence @default(low)
  owner            String?
  last_reviewed_at DateTime?
  next_review_at   DateTime?
  agent_instruction String?   @db.Text
  created_at       DateTime   @default(now())
  updated_at       DateTime   @updatedAt

  @@map("platform_rules")
}

// ============================================================
// Audit
// ============================================================

model AuditLog {
  id              String   @id @default(uuid()) @db.Uuid
  actor           String
  action          String
  object_type     String
  object_id       String?  @db.Uuid
  input_hash      String?
  output_hash     String?
  result          String?
  policy_decision String?
  timestamp       DateTime @default(now())

  @@index([actor])
  @@index([action])
  @@index([object_type, object_id])
  @@index([timestamp])
  @@map("audit_logs")
}

// ============================================================
// Algorithm Intelligence
// ============================================================

enum RuleSource {
  official_docs
  third_party_research
  internal_analytics
}

model ReachOptimizationRule {
  id               String     @id @default(uuid()) @db.Uuid
  platform         String
  rule_type        String
  rule_value       String     @db.Text
  source_url       String?
  source_type      RuleSource @default(official_docs)
  confidence       Confidence @default(low)
  owner            String?
  last_reviewed_at DateTime?
  next_review_at   DateTime?
  created_at       DateTime   @default(now())
  updated_at       DateTime   @updatedAt

  @@map("reach_optimization_rules")
}

// ============================================================
// SAIF Decision Records
// ============================================================

enum DecisionStatus {
  draft
  context_gathering
  proposed
  evaluating
  authority_review
  accepted
  rejected
  deferred
  execution_ready
  superseded
  audited
}

enum DecisionRole {
  context
  proposer
  evaluator
  authority
}

enum EvaluationDimension {
  capability_impact
  security_posture
  cost
  latency
  maintainability
  reversibility
  human_oversight
  compliance
  observability
  learning_potential
}

enum RatingValue {
  positive
  neutral
  negative
}

enum FreshnessStatus {
  fresh
  stale
  expired
  unknown
}

enum HandoffStatus {
  pending
  acknowledged
  validating
  ready
  in_progress
  executing
  completed
  blocked
  failed
  cancelled
}

model SaifDecisionRecord {
  id                      String         @id @default(uuid()) @db.Uuid
  title                   String
  description             String?        @db.Text
  decision_scope          String
  complexity              String?        @default("medium")
  status                  DecisionStatus @default(draft)
  parent_decision_id      String?        @db.Uuid
  human_user_id           String         @db.Uuid
  agent_rep_id            String         @db.Uuid
  authority_user_id       String?        @db.Uuid
  authority_agent_rep_id  String?        @db.Uuid
  rationale               String?        @db.Text
  alternatives_considered String?        @db.Text
  confidence              Confidence     @default(low)
  risk_acceptance         String?        @db.Text
  execution_readiness     Boolean        @default(false)
  success_criteria        String?        @db.Text
  created_at              DateTime       @default(now())
  updated_at              DateTime       @updatedAt

  human_user          User                    @relation("DecisionHumanUser", fields: [human_user_id], references: [id])
  agent_rep           AgentRep                @relation("DecisionAgentRep", fields: [agent_rep_id], references: [id])
  authority_user      User?                   @relation("DecisionAuthorityUser", fields: [authority_user_id], references: [id])
  authority_agent_rep AgentRep?               @relation("DecisionAuthorityAgentRep", fields: [authority_agent_rep_id], references: [id])
  parent_decision     SaifDecisionRecord?     @relation("DecisionHierarchy", fields: [parent_decision_id], references: [id])
  child_decisions     SaifDecisionRecord[]    @relation("DecisionHierarchy")

  roles             DecisionRoleAssignment[]
  evaluations       DecisionEvaluation[]
  execution_handoff DecisionExecutionHandoff?
  dks_links         DecisionDksLink[]
  approvals         Approval[]
  resolutions       CapabilityResolution[]
  mcp_requests      McpMediationRequest[]
  spine_runs        SpineRun[]
  spine_artifacts   SpineArtifact[]

  @@index([human_user_id])
  @@index([agent_rep_id])
  @@index([status])
  @@index([parent_decision_id])
  @@map("saif_decision_records")
}

model DecisionRoleAssignment {
  id                  String       @id @default(uuid()) @db.Uuid
  decision_id         String       @db.Uuid
  role                DecisionRole
  human_user_id       String?      @db.Uuid
  agent_rep_id        String?      @db.Uuid
  functional_agent_id String?      @db.Uuid
  governance_agent_id String?      @db.Uuid
  assigned_at         DateTime     @default(now())

  decision          SaifDecisionRecord @relation(fields: [decision_id], references: [id])
  human_user        User?              @relation("RoleHumanUser", fields: [human_user_id], references: [id])
  agent_rep         AgentRep?          @relation("RoleAgentRep", fields: [agent_rep_id], references: [id])
  functional_agent  FunctionalAgent?   @relation(fields: [functional_agent_id], references: [id])
  governance_agent  GovernanceAgent?   @relation(fields: [governance_agent_id], references: [id])

  @@index([decision_id])
  @@index([role])
  @@map("decision_role_assignments")
}

model DecisionEvaluation {
  id           String              @id @default(uuid()) @db.Uuid
  decision_id  String              @db.Uuid
  dimension    EvaluationDimension
  rating       RatingValue
  assessment   String?             @db.Text
  notes        String?             @db.Text
  mitigation   String?             @db.Text
  evaluated_by String?             @db.Uuid
  evaluated_at DateTime            @default(now())

  decision SaifDecisionRecord @relation(fields: [decision_id], references: [id])

  @@unique([decision_id, dimension])
  @@index([decision_id])
  @@map("decision_evaluations")
}

model DecisionExecutionHandoff {
  id                       String        @id @default(uuid()) @db.Uuid
  decision_id              String        @unique @db.Uuid
  implementation_spec      String?       @db.Text
  constraints              String?       @db.Text
  acceptance_criteria      String?       @db.Text
  expected_outcome         String?       @db.Text
  handoff_status           HandoffStatus @default(pending)
  handoff_to_agent_rep_id  String?       @db.Uuid
  acknowledged_at          DateTime?
  created_at               DateTime      @default(now())
  updated_at               DateTime      @updatedAt

  decision             SaifDecisionRecord @relation(fields: [decision_id], references: [id])
  handoff_to_agent_rep AgentRep?          @relation("HandoffAgentRep", fields: [handoff_to_agent_rep_id], references: [id])

  @@map("decision_execution_handoffs")
}

// ============================================================
// Domain Knowledge Substrate (DKS)
// ============================================================

enum DksSourceType {
  official_docs
  official_policy
  internal_benchmark
  team_decision
  third_party_research
  internal_analytics
  saif_decision
  platform_rule
  learning_insight
}

model DksEntry {
  id               String           @id @default(uuid()) @db.Uuid
  title            String
  description      String?          @db.Text
  source           String?
  source_type      DksSourceType    @default(team_decision)
  version          String?          @default("1.0")
  confidence       Confidence       @default(low)
  last_reviewed_at DateTime?
  freshness_status FreshnessStatus  @default(unknown)
  owner            String?
  tags             String[]
  summary          String?          @db.Text
  content          Json?
  created_at       DateTime         @default(now())
  updated_at       DateTime         @updatedAt

  decision_links DecisionDksLink[]

  @@index([source_type])
  @@index([freshness_status])
  @@index([owner])
  @@map("dks_entries")
}

model DecisionDksLink {
  id            String   @id @default(uuid()) @db.Uuid
  decision_id   String   @db.Uuid
  dks_entry_id  String   @db.Uuid
  link_context  String   @default("evaluation")
  created_at    DateTime @default(now())

  decision  SaifDecisionRecord @relation(fields: [decision_id], references: [id])
  dks_entry DksEntry           @relation(fields: [dks_entry_id], references: [id])

  @@unique([decision_id, dks_entry_id])
  @@index([decision_id])
  @@index([dks_entry_id])
  @@map("decision_dks_links")
}

// ============================================================
// Approval Workflow
// ============================================================

enum ApprovalTargetType {
  campaign
  content_item
  draft_version
  saif_decision_record
}

enum ApprovalStatus {
  pending
  approved
  rejected
  changes_requested
  escalated
  expired
  cancelled
}

enum ApprovalType {
  department_review
  brand_review
  compliance_review
  cco_review
  demand_generation_review
  conversion_review
  customer_growth_review
  revenue_operations_review
}

model Approval {
  id                       String            @id @default(uuid()) @db.Uuid
  target_type              ApprovalTargetType
  target_id                String            @db.Uuid
  saif_decision_record_id  String?           @db.Uuid
  requester_user_id        String            @db.Uuid
  requester_agent_rep_id   String            @db.Uuid
  approver_user_id         String?           @db.Uuid
  approver_agent_rep_id    String?           @db.Uuid
  approval_type            ApprovalType      @default(department_review)
  approval_status          ApprovalStatus    @default(pending)
  decision                 String?
  comment                  String?           @db.Text
  rationale                String?           @db.Text
  risk_category            String            @default("low")
  required_department      String?
  required_role            String?
  requested_at             DateTime          @default(now())
  decided_at               DateTime?
  expires_at               DateTime?
  escalated_at             DateTime?
  created_at               DateTime          @default(now())
  updated_at               DateTime          @updatedAt

  requester_user      User                @relation("ApprovalRequesterUser", fields: [requester_user_id], references: [id])
  requester_agent_rep AgentRep            @relation("ApprovalRequesterAgentRep", fields: [requester_agent_rep_id], references: [id])
  approver_user       User?               @relation("ApprovalApproverUser", fields: [approver_user_id], references: [id])
  approver_agent_rep  AgentRep?           @relation("ApprovalApproverAgentRep", fields: [approver_agent_rep_id], references: [id])
  saif_decision       SaifDecisionRecord? @relation(fields: [saif_decision_record_id], references: [id])
  mcp_requests        McpMediationRequest[]
  spine_runs          SpineRun[]
  spine_artifacts     SpineArtifact[]

  @@index([target_type, target_id])
  @@index([approval_status])
  @@index([requester_user_id])
  @@index([approver_user_id])
  @@index([required_department])
  @@index([risk_category])
  @@map("approvals")
}

// ============================================================
// Capability Registry & Resolution
// ============================================================

enum IntentStatus {
  active
  fulfilled
  abandoned
  superseded
}

enum ObjectiveStatus {
  active
  achieved
  failed
  abandoned
}

enum CapabilityRiskLevel {
  low
  medium
  high
  critical
}

enum ResolutionStatus {
  pending
  resolved
  rejected
  blocked
  deferred
}

model Intent {
  id                  String       @id @default(uuid()) @db.Uuid
  name                String
  description         String?      @db.Text
  category            String?
  source_type         String?
  created_by_user_id  String       @db.Uuid
  created_by_agent_rep_id String   @db.Uuid
  status              IntentStatus @default(active)
  created_at          DateTime     @default(now())
  updated_at          DateTime     @updatedAt

  created_by_user      User     @relation(fields: [created_by_user_id], references: [id])
  created_by_agent_rep AgentRep @relation(fields: [created_by_agent_rep_id], references: [id])
  objectives           Objective[]
  resolutions          CapabilityResolution[]

  @@index([status])
  @@index([created_by_user_id])
  @@map("intents")
}

model Objective {
  id              String         @id @default(uuid()) @db.Uuid
  intent_id       String         @db.Uuid
  name            String
  description     String?        @db.Text
  success_criteria String?       @db.Text
  constraints     String?        @db.Text
  priority        Int            @default(0)
  status          ObjectiveStatus @default(active)
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  intent      Intent                 @relation(fields: [intent_id], references: [id])
  resolutions CapabilityResolution[]

  @@index([intent_id])
  @@index([status])
  @@map("objectives")
}

model Capability {
  id                   String             @id @default(uuid()) @db.Uuid
  name                 String             @unique
  description          String?            @db.Text
  category             String?
  owner_substrate      String?
  risk_level           CapabilityRiskLevel @default(low)
  requires_approval    Boolean            @default(false)
  requires_saif_decision Boolean          @default(false)
  allowed_agent_types  String[]
  created_at           DateTime           @default(now())
  updated_at           DateTime           @updatedAt

  execution_patterns ExecutionPattern[]
  implementations    Implementation[]
  resolutions        CapabilityResolution[]
  mcp_bindings       McpCapabilityBinding[]

  @@index([category])
  @@index([risk_level])
  @@map("capabilities")
}

model ExecutionPattern {
  id               String   @id @default(uuid()) @db.Uuid
  capability_id    String   @db.Uuid
  name             String
  description      String?  @db.Text
  ordered_steps    Json
  required_inputs  String[]
  expected_outputs String[]
  boundary_rules   Json?
  m4_allowed       Boolean  @default(true)
  m5_required      Boolean  @default(false)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  capability    Capability            @relation(fields: [capability_id], references: [id])
  resolutions   CapabilityResolution[]

  @@index([capability_id])
  @@map("execution_patterns")
}

model Resource {
  id                 String   @id @default(uuid()) @db.Uuid
  name               String   @unique
  resource_type      String
  canonical_owner    String?
  external_reference String?
  sensitivity        String?
  access_rules       Json?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  implementation_resources ImplementationResource[]

  @@index([resource_type])
  @@map("resources")
}

model Implementation {
  id                 String   @id @default(uuid()) @db.Uuid
  capability_id      String   @db.Uuid
  name               String
  implementation_type String
  provider           String?
  is_external        Boolean  @default(false)
  requires_mcp       Boolean  @default(false)
