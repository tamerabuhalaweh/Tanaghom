# ============================================================
# Tanaghum Platform — Environment Variables
# Copy to .env and fill in values. NEVER commit .env.
# ============================================================

# --- Application ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- PostgreSQL ---
DATABASE_URL=postgresql://tanaghum:tanaghum_dev@localhost:5432/tanaghum?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_EXPIRY=24h

# --- LLM Provider (mock until Sprint 3) ---
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_MODEL=

# --- Postiz (mock until Sprint 6) ---
POSTIZ_PROVIDER=mock
POSTIZ_API_URL=http://localhost:5000
POSTIZ_API_KEY=
POSTIZ_CLI_PATH=

# --- Messaging (mock until Sprint 5) ---
MESSAGING_PROVIDER=mock
MESSAGING_CHANNEL=
SLACK_BOT_TOKEN=
WHATSAPP_API_TOKEN=
TELEGRAM_BOT_TOKEN=

# --- CRM (mock until Sprint 9) ---
CRM_PROVIDER=mock
CRM_API_URL=
CRM_API_KEY=

# --- Analytics (mock until Sprint 7) ---
ANALYTICS_PROVIDER=mock
