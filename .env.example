# ============================================================
# Tanaghum Platform — Environment Variables
# Copy to .env and fill in values. NEVER commit .env.
# ============================================================

# --- Application ---
NODE_ENV=development
PORT=4000
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:3000

# --- PostgreSQL ---
DATABASE_URL=postgresql://tanaghum:tanaghum_dev@localhost:5432/tanaghum?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
# MUST be at least 32 characters. MUST NOT use dev fallback in production/demo.
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_EXPIRY=24h

# --- Execution Kill Switches ---
# All live integrations disabled by default. Set to 'true' only with explicit approval.
EXTERNAL_EXECUTION_ENABLED=false
M5_WRITE_EXECUTION_ENABLED=false
POSTIZ_LIVE_ENABLED=false
CRM_LIVE_ENABLED=false
WHATSAPP_LIVE_ENABLED=false
RENDERING_LIVE_ENABLED=false
RESOURCESPACE_LIVE_ENABLED=false
PAPERCLIP_SYNC_ENABLED=false
ANALYTICS_LIVE_ENABLED=false

# --- Demo Mode ---
DEMO_MODE=true

# --- LLM Provider (mock) ---
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_MODEL=
GEMMA_BASE_URL=https://api.thesmartlabs.net/gemma4/v1
GEMMA_MODEL=gemma4-26b-a4b-canary
GEMMA_API_KEY=

# --- Postiz (mock) ---
POSTIZ_PROVIDER=mock
POSTIZ_API_URL=
POSTIZ_API_KEY=

# --- Messaging (mock) ---
MESSAGING_PROVIDER=mock
MESSAGING_CHANNEL=
SLACK_BOT_TOKEN=
WHATSAPP_API_TOKEN=
TELEGRAM_BOT_TOKEN=

# --- CRM (mock) ---
CRM_PROVIDER=mock
CRM_API_URL=
CRM_API_KEY=

# --- Analytics (mock) ---
ANALYTICS_PROVIDER=mock
